generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["prolt_energy", "public"]
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(50)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([username])
  @@index([email])
  @@schema("public")
}

model Dataset {
  id            String          @id @default(uuid())
  market        MarketType
  deliveryDate  DateTime        @db.Date
  fileName      String          @db.VarChar(255)
  status        DatasetStatus   @default(ACTIVE)
  uploadedAt    DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  damRecords    DamRecord[]
  gdamRecords   GdamRecord[]
  rtmRecords    RtmRecord[]
  uploadHistory UploadHistory[]

  @@index([market])
  @@index([deliveryDate])
  @@index([status])
  @@index([market, deliveryDate])
  @@schema("public")
}

model UploadHistory {
  id           String       @id @default(uuid())
  datasetId    String
  market       MarketType
  deliveryDate DateTime     @db.Date
  action       UploadAction
  timestamp    DateTime     @default(now())
  dataset      Dataset      @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId])
  @@index([market])
  @@index([deliveryDate])
  @@index([action])
  @@index([timestamp])
  @@schema("public")
}

model DamRecord {
  id             String  @id @default(uuid())
  datasetId      String
  intervalNumber Int     @db.SmallInt
  intervalTime   String  @db.VarChar(15)
  purchaseBid    Decimal @db.Decimal(18, 4)
  sellBid        Decimal @db.Decimal(18, 4)
  mcv            Decimal @db.Decimal(18, 4)
  fsv            Decimal @db.Decimal(18, 4)
  mcp            Decimal @db.Decimal(18, 4)
  dataset        Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, intervalNumber])
  @@index([datasetId])
  @@index([intervalNumber])
  @@index([intervalTime])
  @@schema("public")
}

model GdamRecord {
  id              String  @id @default(uuid())
  datasetId       String
  intervalNumber  Int     @db.SmallInt
  intervalTime    String  @db.VarChar(15)
  purchaseBid     Decimal @db.Decimal(18, 4)
  sellBidTotal    Decimal @db.Decimal(18, 4)
  sellBidSolar    Decimal @db.Decimal(18, 4)
  sellBidNonSolar Decimal @db.Decimal(18, 4)
  sellBidHydro    Decimal @db.Decimal(18, 4)
  mcvTotal        Decimal @db.Decimal(18, 4)
  mcvSolar        Decimal @db.Decimal(18, 4)
  mcvNonSolar     Decimal @db.Decimal(18, 4)
  mcvHydro        Decimal @db.Decimal(18, 4)
  fsvTotal        Decimal @db.Decimal(18, 4)
  fsvSolar        Decimal @db.Decimal(18, 4)
  fsvNonSolar     Decimal @db.Decimal(18, 4)
  fsvHydro        Decimal @db.Decimal(18, 4)
  mcp             Decimal @db.Decimal(18, 4)
  dataset         Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, intervalNumber])
  @@index([datasetId])
  @@index([intervalNumber])
  @@index([intervalTime])
  @@schema("public")
}

model RtmRecord {
  id             String  @id @default(uuid())
  datasetId      String
  intervalNumber Int     @db.SmallInt
  intervalTime   String  @db.VarChar(15)
  sessionId      String  @db.VarChar(50)
  purchaseBid    Decimal @db.Decimal(18, 4)
  sellBid        Decimal @db.Decimal(18, 4)
  mcv            Decimal @db.Decimal(18, 4)
  fsv            Decimal @db.Decimal(18, 4)
  mcp            Decimal @db.Decimal(18, 4)
  dataset        Dataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, intervalNumber])
  @@index([datasetId])
  @@index([intervalNumber])
  @@index([intervalTime])
  @@schema("public")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model RegionState {
  id           Int            @id @default(autoincrement())
  regionalGrid String?        @map("regional_grid") @db.VarChar(30)
  regionCode   String?        @map("region_code") @db.VarChar(10)
  regionName   String?        @map("region_name") @db.VarChar(50)
  stateName    String         @map("state_name") @db.VarChar(50)
  stateCode    Int?           @unique(map: "uq_region_state_code") @map("state_code")
  stateOrUt    state_ut_enum? @map("state_or_ut")

  @@map("region_state")
  @@schema("prolt_energy")
}

model DiscomList {
  code       String  @unique(map: "uq_discom_list_code") @db.VarChar(20)
  legalName  String  @unique(map: "uq_discom_list_name") @map("legal_name") @db.VarChar(255)
  stateCode  Int?    @map("state_code")
  discomType String? @map("discom_type") @db.VarChar(30)
  id         Int     @id @default(autoincrement())

  @@map("discom_list")
  @@schema("prolt_energy")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model IstsCharges {
  id              Int     @id @default(autoincrement())
  state           String  @db.VarChar(50)
  date            Int
  istsLossPercent Decimal @map("ists_loss_percent") @db.Decimal(6, 4)

  @@unique([state, date], map: "uq_ists_charges_state_date")
  @@map("ists_charges")
  @@schema("prolt_energy")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model IexFees {
  id                  Int      @id @default(autoincrement())
  month               Int?     @unique(map: "uq_iex_fees_month")
  exchangeFees        Decimal? @map("exchange_fees") @db.Decimal(12, 4)
  exchangeFeesGst     Decimal? @map("exchange_fees_gst") @db.Decimal(12, 4)
  nldcApplicationFees Decimal? @map("nldc_application_fees") @db.Decimal(12, 4)
  nldcSchedulingFees  Decimal? @map("nldc_scheduling_fees") @db.Decimal(12, 4)
  sldcSchedulingFees  Decimal? @map("sldc_scheduling_fees") @db.Decimal(12, 4)
  otherFixCharges     Decimal? @map("other_fix_charges") @db.Decimal(12, 4)

  @@map("iex_fees")
  @@schema("prolt_energy")
}

model ProltMargin {
  month            Int
  customerId       String   @map("customer_id") @db.VarChar(50)
  tradingMargin    Decimal? @map("trading_margin") @db.Decimal(12, 4)
  tradingMarginGst Decimal? @map("trading_margin_gst") @db.Decimal(12, 4)
  proltMargin      Decimal? @map("prolt_margin") @db.Decimal(12, 4)
  proltMarginGst   Decimal? @map("prolt_margin_gst") @db.Decimal(12, 4)
  id               Int      @id @default(autoincrement())

  @@unique([month, customerId], map: "uq_prolt_margin_month_cust")
  @@map("prolt_margin")
  @@schema("prolt_energy")
}


model CtuCharges {
  id        Int      @id @default(autoincrement())
  month     Int      // 1-12
  year      Int      // e.g. 2026
  pdfUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, year], map: "uq_ctu_charges_month_year")
  @@map("ctu_charges")
  @@schema("prolt_energy")
}

model IstsChargeDocs {
  id        Int      @id @default(autoincrement())
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date
  year      Int
  pdfUrl    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekStart, weekEnd, year], map: "uq_ists_charge_docs_week_year")
  @@map("ists_charge_docs")
  @@schema("prolt_energy")
}


model StuCharges {
  stateCode                           Int      @map("state_code")
  state                               String   @db.VarChar(100)
  category                            String?  @db.VarChar(50)
  subCategory                         String?  @map("sub_category") @db.VarChar(100)
  voltageLevel                        String?  @map("voltage_level") @db.VarChar(20)
  month                               Int
  stuChargesRsPerKwh                  Decimal? @map("stu_charges_rs_per_kwh") @db.Decimal(12, 6)
  demandCharges                       Decimal? @map("demand_charges") @db.Decimal(12, 6)
  percentFppaCharges                  Decimal? @map("percent_fppa_charges") @db.Decimal(12, 6)
  additionalCharges                   Decimal? @map("additional_charges") @db.Decimal(12, 6)
  crossSubsidy                        Decimal? @map("cross_subsidy") @db.Decimal(12, 6)
  distributionWheelingChargesRsPerKwh Decimal? @map("distribution_wheeling_charges_rs_per_kwh") @db.Decimal(12, 6)
  stuLossPercent                      Decimal? @map("stu_loss_percent") @db.Decimal(12, 6)
  distributionWheelingLossPercent     Decimal? @map("distribution_wheeling_loss_percent") @db.Decimal(12, 6)
  id                                  Int      @id @default(autoincrement())

  @@unique([stateCode, month, category, subCategory, voltageLevel], map: "uq_stu_charges_composite")
  @@map("stu_charges")
  @@schema("prolt_energy")
}

model StateTariff {
  stateCode         Int      @map("state_code")
  month             Int
  state             String   @db.VarChar(100)
  category          String?  @db.VarChar(50)
  subCategory       String?  @map("sub_category") @db.VarChar(100)
  voltageLevel      String?  @map("voltage_level") @db.VarChar(20)
  tod               String   @db.VarChar(50)
  todName           String?  @map("tod_name") @db.VarChar(255)
  season            String?  @db.VarChar(50)
  todStartHour      String?  @map("tod_start_hour") @db.VarChar(20)
  todEndHour        String?  @map("tod_end_hour") @db.VarChar(20)
  baseEnergyCharges Decimal? @map("base_energy_charges") @db.Decimal(12, 6)
  todRate           Decimal? @map("tod_rate") @db.Decimal(12, 6)
  energyCharges     Decimal? @map("energy_charges") @db.Decimal(12, 6)
  id                Int      @id @default(autoincrement())

  @@unique([stateCode, month, category, subCategory, voltageLevel, season, todName, tod], map: "uq_state_tariff_composite")
  @@map("state_tariff")
  @@schema("prolt_energy")
}

model user_details {
  customer_id             String   @id @db.VarChar(50)
  address_line1           String?  @db.VarChar(255)
  address_line2           String?  @db.VarChar(255)
  address_pin_code        Int?
  address_state           String?  @db.VarChar(100)
  billing_address_line1   String?  @db.VarChar(255)
  billing_address_line2   String?  @db.VarChar(255)
  billing_pin_code        Int?
  billing_state           String?  @db.VarChar(100)
  contact_person_name     String?  @db.VarChar(100)
  contact_email           String?  @db.VarChar(255)
  contact_phone           String?  @db.VarChar(20)
  contact_whatsapp_number String?  @db.VarChar(20)
  contact_alternate_phone String?  @db.VarChar(20)
  factory_name            String?  @db.VarChar(255)
  gst_number              String?  @db.VarChar(30)
  sanctioned_load_kw      Decimal? @db.Decimal(12, 2)
  discom                  String?  @db.VarChar(20)
  state                   String?  @db.VarChar(100)
  supply_voltage          String?  @db.VarChar(10)
  category                String?  @db.VarChar(10)
  sub_category            String?  @db.VarChar(10)

  @@schema("prolt_energy")
}


enum MarketType {
  DAM
  GDAM
  RTM

  @@schema("public")
}

enum DatasetStatus {
  ACTIVE
  REPLACED
  DELETED

  @@schema("public")
}

enum UploadAction {
  UPLOAD
  REPLACE
  DELETE

  @@schema("public")
}

enum state_ut_enum {
  state
  ut

  @@schema("prolt_energy")
}

model StateDemandData {
  id        String   @id @default(uuid())
  stateName String
  date      String   @db.VarChar(10) // YYYY-MM-DD
  timeStr   String   @db.VarChar(10) // HH:MM
  demand    Int
  unit      String
  region    String
  price     Float
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([stateName, date, timeStr])
  @@schema("public")
}

model WeatherForecast {
  id        String   @id @default(uuid())
  date      String   @unique @db.VarChar(10) // YYYY-MM-DD
  maxTemp           Float
  minTemp           Float
  windSpeed         Float
  relativeHumidity  Float    @default(0)
  precipitationProb Float    @default(0)
  precipitationSum  Float    @default(0)
  sunshineDuration  Float    @default(0)
  sunrise           String   @default("") @db.VarChar(10)
  sunset            String   @default("") @db.VarChar(10)
  isActual          Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt

  @@schema("public")
}

model NppRawDemandData {
  id            String   @id @default(uuid())
  date          String   // e.g., '2026-07-01'
  timeStr       String   // e.g., '00:03'
  demandMet     Float
  dataUpdatedAt String?  // The time at which they updated the data
  fetchedAt     DateTime @default(now()) // The time at which we fetched the data
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([date, timeStr], map: "uq_npp_date_time")
  @@index([date])
  @@schema("public")
}

model NppRawGenerationData {
  id            String   @id @default(uuid())
  date          String   // e.g., '2026-07-01'
  timeStr       String   // e.g., '00:03'
  thermal       Float?
  gas           Float?
  nuclear       Float?
  hydro         Float?
  wind          Float?
  solar         Float?
  dataUpdatedAt String?  // The time at which they updated the data
  fetchedAt     DateTime @default(now()) // The time at which we fetched the data
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([date, timeStr], map: "uq_npp_gen_date_time")
  @@index([date])
  @@schema("public")
}

model HolidayCalendar {
  id          String   @id @default(uuid())
  month       String   @db.VarChar(20)
  holidayDate String   @db.VarChar(10) // DD-MM-YYYY
  holidayName String   @db.VarChar(255)
  holidayType String   @db.VarChar(50)
  state       String   @db.VarChar(100)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("public")
}

model ApiLog {
  id        String   @id @default(uuid())
  apiName   String   @db.VarChar(100)
  endpoint  String?  @db.VarChar(255)
  status    String   @db.VarChar(50) // SUCCESS, ERROR
  message   String?  @db.Text
  createdAt DateTime @default(now())

  @@index([apiName])
  @@index([status])
  @@index([createdAt])
  @@schema("public")
}
